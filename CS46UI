            Parent = track,
        })
        Util.Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = fill })
        
        local thumb = Util.Create("Frame", {
            Size = UDim2.new(0, 12, 0, 12),
            Position = UDim2.new(pct, -6, 0.5, -6),
            BackgroundColor3 = t.Text0,
            BorderSizePixel = 0,
            ZIndex = 5,
            Parent = track,
        })
        Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })
        
        -- Slider interaction
        local trackButton = Util.Create("TextButton", {
            Size = UDim2.new(1, 0, 1, 8),
            Position = UDim2.new(0, 0, 0, -4),
            BackgroundTransparency = 1,
            Text = "",
            ZIndex = 6,
            Parent = track,
        })
        
        local dragging = false
        
        local function updateSlider(inputX)
            local absPos = track.AbsolutePosition.X
            local absSize = track.AbsoluteSize.X
            local relX = math.clamp((inputX - absPos) / absSize, 0, 1)
            
            local rawVal = min + relX * (max - min)
            local stepped = math.floor(rawVal / step + 0.5) * step
            value = math.clamp(stepped, min, max)
            
            local newPct = (value - min) / (max - min)
            fill.Size = UDim2.new(newPct, 0, 1, 0)
            thumb.Position = UDim2.new(newPct, -6, 0.5, -6)
            valLabel.Text = (step >= 1 and tostring(math.floor(value)) or string.format("%.1f", value)) .. suffix
            
            if flag then self:SetFlag(flag, value) end
            cb(value)
        end
        
        trackButton.MouseButton1Down:Connect(function()
            dragging = true
            updateSlider(Mouse.X)
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                updateSlider(input.Position.X)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        if flag then self:SetFlag(flag, value) end
        
        -- Theme update refs
        local sliderObj = {
            _fill = fill,
            _nameL = nameL,
            _valLabel = valLabel,
            _track = track,
            _thumb = thumb,
        }
        
        t:OnUpdate(function()
            fill.BackgroundColor3 = t.Accent
            nameL.TextColor3 = t.Text2
            valLabel.TextColor3 = t.Text1
            track.BackgroundColor3 = t.BG4
            thumb.BackgroundColor3 = t.Text0
        end)
        
        return sliderObj
    end
    
