-- ============================================================
-- ADD TAB
-- ============================================================
function ClientUI:AddTab(config)
    config = config or {}
    local name = config.Name or "Tab"
    local icon = config.Icon or TabIcons[name:lower()] or TabIcons.default
    local theme = self.Theme
    
    local tab = {
        Name = name,
        Modules = {},
        Button = nil,
        Content = nil,
    }
    
    -- Tab button
    local tabOrder = #self.Tabs
    
    local tabBtn = Util.Create("TextButton", {
        Name = "Tab_" .. name,
        Size = UDim2.new(0, 48, 0, 44),
        BackgroundColor3 = theme.BG0,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        ZIndex = 8,
        LayoutOrder = tabOrder,
        Parent = self.TabButtonContainer,
    })
    
    Util.Create("UICorner", { CornerRadius = UDim.new(0, 12), Parent = tabBtn })
    
    local iconLabel = Util.Create("TextLabel", {
        Name = "Icon",
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1,
        Text = icon,
        TextSize = 17,
        Font = Enum.Font.GothamBold,
        TextColor3 = theme.Text3,
        ZIndex = 9,
        Parent = tabBtn,
    })
    
    local textLabel = Util.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(0, 0, 1, 0),
        Position = UDim2.new(0, 38, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextColor3 = theme.Text3,
        TextTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 9,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = tabBtn,
    })
    
    tab.Button = tabBtn
    tab.IconLabel = iconLabel
    tab.TextLabel = textLabel
    
    -- Tab content (3-column grid)
    local content = Util.Create("Frame", {
        Name = "Content_" .. name,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Visible = false,
        ZIndex = 2,
        Parent = self.ContentFrame,
    })
    
    -- Three column layout
    local columnsFrame = Util.Create("Frame", {
        Name = "Columns",
        Size = UDim2.new(1, -36, 0, 0),
        Position = UDim2.new(0, 18, 0, 18),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = content,
    })
    
    local columns = {}
    for i = 1, 3 do
        local col = Util.Create("Frame", {
            Name = "Column" .. i,
            Size = UDim2.new(1/3, -7, 0, 0),
            Position = UDim2.new((i-1)/3, (i == 1 and 0 or (i == 2 and 3 or 7)), 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Parent = columnsFrame,
        })
        Util.Create("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 10),
            Parent = col,
        })
        columns[i] = col
    end
    
    tab.Content = content
    tab.Columns = columns
    tab.ModuleCount = 0
    
    -- Tab button click
    tabBtn.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)
    
    tabBtn.MouseEnter:Connect(function()
        if self.ActiveTab ~= tab then
            Util.Tween(iconLabel, {TextColor3 = theme.Text2}, 0.15)
            Util.Tween(tabBtn, {BackgroundTransparency = 0, BackgroundColor3 = theme.BG0}, 0.15)
        end
    end)
    
    tabBtn.MouseLeave:Connect(function()
        if self.ActiveTab ~= tab then
            Util.Tween(iconLabel, {TextColor3 = theme.Text3}, 0.15)
            Util.Tween(tabBtn, {BackgroundTransparency = 1}, 0.15)
        end
    end)
    
    table.insert(self.Tabs, tab)
    
    -- Auto-select first tab
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    
    -- Return a Tab object with :AddModule
    local tabObj = {}
    tabObj._tab = tab
    tabObj._client = self
    
    function tabObj:AddModule(moduleConfig)
        return self._client:AddModule(self._tab, moduleConfig)
    end
    
    return tabObj
end

function ClientUI:SelectTab(tab)
    local theme = self.Theme
    
    self:CloseAllDropdowns()
    self:CloseColorPicker()
    
    -- Deactivate all
    for _, t in ipairs(self.Tabs) do
        t.Content.Visible = false
        Util.Tween(t.IconLabel, {TextColor3 = theme.Text3}, 0.2)
        Util.Tween(t.TextLabel, {TextTransparency = 1, Size = UDim2.new(0, 0, 1, 0)}, 0.25)
        Util.Tween(t.Button, {BackgroundTransparency = 1, Size = UDim2.new(0, 48, 0, 44)}, 0.25)
    end
    
    -- Activate selected
    self.ActiveTab = tab
    tab.Content.Visible = true
    Util.Tween(tab.IconLabel, {TextColor3 = theme.Accent}, 0.2)
    Util.Tween(tab.TextLabel, {TextTransparency = 0, Size = UDim2.new(0, 80, 1, 0), TextColor3 = theme.Accent}, 0.25)
    Util.Tween(tab.Button, {BackgroundTransparency = 0, BackgroundColor3 = theme.BG2, Size = UDim2.new(0, 130, 0, 44)}, 0.25)
end

