-- ============================================================
-- UTILITY
-- ============================================================
local Util = {}

function Util.Create(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    if props and props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

function Util.Tween(obj, props, duration, style, dir)
    local info = TweenInfo.new(duration or 0.25, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    local tween = TweenService:Create(obj, info, props)
    tween:Play()
    return tween
end

function Util.Hex(color)
    return string.format("#%02x%02x%02x", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))
end

function Util.HexToColor3(hex)
    hex = hex:gsub("#", "")
    if #hex < 6 then return Color3.fromRGB(136, 136, 136) end
    local r = tonumber(hex:sub(1, 2), 16) or 136
    local g = tonumber(hex:sub(3, 4), 16) or 136
    local b = tonumber(hex:sub(5, 6), 16) or 136
    return Color3.fromRGB(r, g, b)
end

function Util.HSVtoRGB(h, s, v)
    return Color3.fromHSV(h, s, v)
end

function Util.RGBtoHSV(color)
    local h, s, v = Color3.toHSV(color)
    return h, s, v
end

function Util.Ripple(frame, pos)
    -- minimal visual feedback
end

function Util.Draggable(gui, handle)
    local dragging, dragInput, dragStart, startPos
    handle = handle or gui

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ============================================================
-- THEME SYSTEM
-- ============================================================
local Theme = {}
Theme.__index = Theme

function Theme.new()
    local self = setmetatable({}, Theme)
    self.Light = false
    self.Accent = Color3.fromRGB(136, 136, 136)
    self.Callbacks = {}
    self:UpdateColors()
    return self
end

function Theme:UpdateColors()
    if self.Light then
        self.BG0 = Color3.fromRGB(240, 240, 240)
        self.BG1 = Color3.fromRGB(228, 228, 228)
        self.BG2 = Color3.fromRGB(255, 255, 255)
        self.BG3 = Color3.fromRGB(240, 240, 240)
        self.BG4 = Color3.fromRGB(221, 221, 221)
        self.BGHover = Color3.fromRGB(232, 232, 232)
        self.Text0 = Color3.fromRGB(26, 26, 26)
        self.Text1 = Color3.fromRGB(85, 85, 85)
        self.Text2 = Color3.fromRGB(119, 119, 119)
        self.Text3 = Color3.fromRGB(170, 170, 170)
        self.Text4 = Color3.fromRGB(187, 187, 187)
        self.Border = Color3.fromRGB(213, 213, 213)
        self.Border2 = Color3.fromRGB(197, 197, 197)
    else
        self.BG0 = Color3.fromRGB(26, 26, 26)
        self.BG1 = Color3.fromRGB(22, 22, 22)
        self.BG2 = Color3.fromRGB(33, 33, 33)
        self.BG3 = Color3.fromRGB(39, 39, 39)
        self.BG4 = Color3.fromRGB(46, 46, 46)
        self.BGHover = Color3.fromRGB(51, 51, 51)
        self.Text0 = Color3.fromRGB(208, 208, 208)
        self.Text1 = Color3.fromRGB(153, 153, 153)
        self.Text2 = Color3.fromRGB(119, 119, 119)
        self.Text3 = Color3.fromRGB(85, 85, 85)
        self.Text4 = Color3.fromRGB(68, 68, 68)
        self.Border = Color3.fromRGB(39, 39, 39)
        self.Border2 = Color3.fromRGB(48, 48, 48)
    end
end

function Theme:SetLight(val)
    self.Light = val
    self:UpdateColors()
    self:FireCallbacks()
end

function Theme:SetAccent(color)
    self.Accent = color
    self:FireCallbacks()
end

function Theme:OnUpdate(callback)
    table.insert(self.Callbacks, callback)
end

function Theme:FireCallbacks()
    for _, cb in ipairs(self.Callbacks) do
        pcall(cb)
    end
end

