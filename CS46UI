	bottomLayout.FillDirection = Enum.FillDirection.Horizontal
	bottomLayout.Padding       = UDim.new(0, 8)
	bottomLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	bottomLayout.SortOrder     = Enum.SortOrder.LayoutOrder
	bottomLayout.Parent        = bottom

	local preview = Instance.new("Frame")
	preview.Name            = "Preview"
	preview.Size            = UDim2.new(0,28,0,24)
	preview.BackgroundColor3 = Color3.fromRGB(255,255,255)
	preview.BorderSizePixel  = 0
	preview.LayoutOrder      = 0
	preview.Parent           = bottom
	U.corner(preview, THEME.RAD_SMALL)
	U.stroke(preview, THEME.BORDER2)

	local hexBox = Instance.new("TextBox")
	hexBox.Name              = "HexBox"
	hexBox.Size              = UDim2.new(1,-36,0,24)
	hexBox.BackgroundColor3  = THEME.BG3
	hexBox.BorderSizePixel   = 0
	hexBox.Text              = "#888888"
	hexBox.TextSize          = 12
	hexBox.Font              = THEME.FONT_MONO
	hexBox.TextColor3        = THEME.TEXT0
	hexBox.ClearTextOnFocus  = false
	hexBox.TextXAlignment    = Enum.TextXAlignment.Left
	hexBox.LayoutOrder       = 1
	hexBox.Parent            = bottom
	U.corner(hexBox, THEME.RAD_SMALL)
	U.stroke(hexBox, THEME.BORDER2)
	U.padding(hexBox, 0, 6, 0, 6)

	cp.Frame   = frame
	cp.SVArea  = svArea
	cp.SVCur   = svCur
	cp.HueBar  = hueBar
	cp.HueCur  = hueCur
	cp.Preview = preview
	cp.HexBox  = hexBox

	cp.H, cp.S, cp.V = 0, 0, 0.53
	cp.CurrentSwatch = nil
	cp.CurrentHexLbl = nil
	cp.CurrentState  = nil
	cp.CurrentCb     = nil
	cp.Drag          = nil

	function cp:getColor()
		return Color3.fromHSV(self.H/360, self.S, self.V)
	end

	function cp:render()
		local hueColor = Color3.fromHSV(self.H/360, 1, 1)
		self.SVArea.BackgroundColor3 = hueColor

		self.SVCur.Position = UDim2.new(self.S, 0, 1-self.V, 0)
		self.HueCur.Position = UDim2.new(self.H/360, 0, 0.5, 0)

		local c = self:getColor()
		self.Preview.BackgroundColor3 = c
		local hex = U.toHex(c)
		self.HexBox.Text = hex

		if self.CurrentSwatch then
			self.CurrentSwatch.BackgroundColor3 = c
		end
		if self.CurrentHexLbl then
			self.CurrentHexLbl.Text = hex
		end
		if self.CurrentState then
			self.CurrentState.Value = c
		end
		if self.CurrentCb then
			self.CurrentCb(c)
		end
	end

	function cp:open(swatch, hexLbl, state, cb)
		if self.CurrentSwatch == swatch and self.Frame.Visible then
			self.Frame.Visible = false
			self.CurrentSwatch = nil
			return
		end
		self.CurrentSwatch = swatch
		self.CurrentHexLbl = hexLbl
		self.CurrentState  = state
		self.CurrentCb     = cb

		local c = swatch.BackgroundColor3
		local h, s, v = Color3.toHSV(c)
		self.H, self.S, self.V = h*360, s, v

		-- Position popup near swatch
		local absPos = swatch.AbsolutePosition
		local absSize = swatch.AbsoluteSize
		local scrSize = self.Frame.Parent.AbsoluteSize

		local px = absPos.X
		local py = absPos.Y + absSize.Y + 6
		if px + popupW > scrSize.X then px = scrSize.X - popupW - 4 end
		if py + popupH > scrSize.Y then py = absPos.Y - popupH - 6 end
		if px < 4 then px = 4 end
		if py < 4 then py = 4 end

		self.Frame.Position = UDim2.new(0, px, 0, py)
		self.Frame.Visible  = true
		self:render()
	end

	-- SV drag
	svArea.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			cp.Drag = "sv"
		end
	end)
	hueBar.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			cp.Drag = "hue"
		end
	end)

	UserInputService.InputChanged:Connect(function(inp)
		if not cp.Frame.Visible then return end
		if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
		if cp.Drag == "sv" then
			local abs = cp.SVArea.AbsolutePosition
			local sz  = cp.SVArea.AbsoluteSize
			cp.S = U.clamp((inp.Position.X - abs.X) / sz.X, 0, 1)
			cp.V = U.clamp(1 - (inp.Position.Y - abs.Y) / sz.Y, 0, 1)
			cp:render()
		elseif cp.Drag == "hue" then
			local abs = cp.HueBar.AbsolutePosition
			local w   = cp.HueBar.AbsoluteSize.X
			cp.H = U.clamp((inp.Position.X - abs.X) / w, 0, 1) * 360
			cp:render()
		end
	end)

	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			cp.Drag = nil
		end
	end)

	-- Hex input
	hexBox.FocusLost:Connect(function()
		local ok, c = pcall(U.fromHex, hexBox.Text)
		if ok and c then
			local h,s,v = Color3.toHSV(c)
			cp.H, cp.S, cp.V = h*360, s, v
			cp:render()
		end
	end)

	-- Close on outside click
	self.ScreenGui.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			if cp.Frame.Visible then
				-- Check if click is inside popup
				local mpos = inp.Position
				local abs  = cp.Frame.AbsolutePosition
				local sz   = cp.Frame.AbsoluteSize
				if mpos.X < abs.X or mpos.X > abs.X + sz.X or
				   mpos.Y < abs.Y or mpos.Y > abs.Y + sz.Y then
					cp.Frame.Visible  = false
					cp.CurrentSwatch  = nil
				end
			end
		end
	end)

	return cp
end

-- ============================================================
-- MODULE ELEMENT: BUTTON
-- ============================================================
function ClientLib:addButton(moduleData, labelText, text, onClick)
	local container = U.frame(moduleData.Frame, UDim2.new(1,0,0,0), nil, Color3.fromRGB(0,0,0), 1)
	container.Name        = "BtnRow_" .. labelText
	container.AutomaticSize = Enum.AutomaticSize.Y
	container.LayoutOrder = moduleData.ElemCount
	moduleData.ElemCount  += 1
	U.listLayout(container, Enum.FillDirection.Vertical, 4)

	if labelText and labelText ~= "" then
		local lbl = U.label(container, labelText, 11, THEME.TEXT2, THEME.FONT)
		lbl.LayoutOrder = 0
	end

	local btn = U.button(container, text, UDim2.new(1,0,0,24))
	btn.LayoutOrder = 1

	btn.MouseButton1Click:Connect(function()
		if onClick then onClick() end
	end)

	return btn
end

-- ============================================================
-- MODULE ELEMENT: TEXT INPUT WITH BUTTON (like BG gif row)
-- ============================================================
function ClientLib:addInputWithButtons(moduleData, labelText, placeholder, buttons, onChange)
	-- buttons = { {text="Apply", onClick=fn}, {text="Clear", onClick=fn} }
	local container = U.frame(moduleData.Frame, UDim2.new(1,0,0,0), nil, Color3.fromRGB(0,0,0), 1)
	container.Name        = "InputBtns_" .. labelText
	container.AutomaticSize = Enum.AutomaticSize.Y
	container.LayoutOrder = moduleData.ElemCount
	moduleData.ElemCount  += 1
	U.listLayout(container, Enum.FillDirection.Vertical, 4)

	local lbl = U.label(container, labelText, 11, THEME.TEXT2, THEME.FONT)
	lbl.LayoutOrder = 0

	local row = U.frame(container, UDim2.new(1,0,0,24), nil, Color3.fromRGB(0,0,0), 1)
	row.LayoutOrder = 1
	local rowLayout = Instance.new("UIListLayout")
	rowLayout.FillDirection = Enum.FillDirection.Horizontal
	rowLayout.Padding       = UDim.new(0, 6)
	rowLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	rowLayout.SortOrder     = Enum.SortOrder.LayoutOrder
	rowLayout.Parent        = row

	-- Calc button widths
	local btnTotalW = 0
	local btnDefs   = buttons or {}
	for _, b in ipairs(btnDefs) do
		btnTotalW = btnTotalW + 54 + 6
	end

	local inputBox = Instance.new("TextBox")
	inputBox.Name              = "Input"
	inputBox.Size              = UDim2.new(1, -btnTotalW, 0, 24)
	inputBox.BackgroundColor3  = THEME.BG3
	inputBox.BorderSizePixel   = 0
	inputBox.Text              = ""
	inputBox.PlaceholderText   = placeholder or ""
	inputBox.TextSize          = 11
	inputBox.Font              = THEME.FONT
	inputBox.TextColor3        = THEME.TEXT0
	inputBox.PlaceholderColor3 = THEME.TEXT4
	inputBox.ClearTextOnFocus  = false
	inputBox.TextXAlignment    = Enum.TextXAlignment.Left
	inputBox.LayoutOrder       = 0
	inputBox.Parent            = row
	U.corner(inputBox, THEME.RAD_ELEM)
	U.stroke(inputBox, THEME.BORDER2)
	U.padding(inputBox, 0, 8, 0, 8)

	if onChange then
		inputBox.FocusLost:Connect(function()
			onChange(inputBox.Text)
		end)
	end

	for i, bd in ipairs(btnDefs) do
		local b = U.button(row, bd.text, UDim2.new(0, 54, 0, 24))
		b.LayoutOrder = i
		if bd.onClick then
			b.MouseButton1Click:Connect(function()
				bd.onClick(inputBox.Text)
			end)
		end
	end

	return {
		getValue = function() return inputBox.Text end,
		setValue = function(v) inputBox.Text = v end,
	}
end

