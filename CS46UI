-- ClientLib.lua
-- A Roblox UI Library inspired by the HTML Client interface

local ClientLib = {}
ClientLib.__index = ClientLib

-- ============================================================
-- SERVICES
-- ============================================================
local Players        = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService   = game:GetService("TweenService")
local RunService     = game:GetService("RunService")
local HttpService    = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local Mouse       = LocalPlayer:GetMouse()

-- ============================================================
-- CONSTANTS / THEME
-- ============================================================
local THEME = {
	-- Backgrounds
	BG0        = Color3.fromRGB(26,  26,  26),
	BG1        = Color3.fromRGB(22,  22,  22),
	BG2        = Color3.fromRGB(33,  33,  33),
	BG3        = Color3.fromRGB(39,  39,  39),
	BG4        = Color3.fromRGB(46,  46,  46),
	BG_HOVER   = Color3.fromRGB(51,  51,  51),

	-- Text
	TEXT0      = Color3.fromRGB(208, 208, 208),
	TEXT1      = Color3.fromRGB(153, 153, 153),
	TEXT2      = Color3.fromRGB(119, 119, 119),
	TEXT3      = Color3.fromRGB(85,  85,  85),
	TEXT4      = Color3.fromRGB(68,  68,  68),

	-- Border
	BORDER     = Color3.fromRGB(39,  39,  39),
	BORDER2    = Color3.fromRGB(48,  48,  48),

	-- Accent
	ACCENT     = Color3.fromRGB(136, 136, 136),

	-- Window size
	WIN_W      = 820,
	WIN_H      = 560,

	-- Tab bar height
	TAB_H      = 52,

	-- Module grid
	COL_COUNT  = 3,
	COL_GAP    = 10,
	MOD_PAD    = 14,

	-- Font
	FONT       = Enum.Font.GothamMedium,
	FONT_BOLD  = Enum.Font.GothamBold,
	FONT_MONO  = Enum.Font.Code,

	-- Corner radius
	RAD_WIN    = 16,
	RAD_MOD    = 12,
	RAD_ELEM   = 8,
	RAD_SMALL  = 6,
}

-- ============================================================
-- UTILITY HELPERS
-- ============================================================
local U = {}

function U.tween(obj, props, t, style, dir)
	local info = TweenInfo.new(
		t    or 0.2,
		style or Enum.EasingStyle.Quad,
		dir  or Enum.EasingDirection.Out
	)
	TweenService:Create(obj, info, props):Play()
end

function U.corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or THEME.RAD_ELEM)
	c.Parent = parent
	return c
end

function U.stroke(parent, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color     = color     or THEME.BORDER
	s.Thickness = thickness or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent    = parent
	return s
end

function U.padding(parent, top, right, bottom, left)
	local p = Instance.new("UIPadding")
	p.PaddingTop    = UDim.new(0, top    or 0)
	p.PaddingRight  = UDim.new(0, right  or 0)
	p.PaddingBottom = UDim.new(0, bottom or 0)
	p.PaddingLeft   = UDim.new(0, left   or 0)
	p.Parent        = parent
	return p
end

function U.listLayout(parent, dir, spacing, ha, va)
	local l = Instance.new("UIListLayout")
	l.FillDirection     = dir     or Enum.FillDirection.Vertical
	l.Padding           = UDim.new(0, spacing or 4)
	l.HorizontalAlignment = ha   or Enum.HorizontalAlignment.Left
	l.VerticalAlignment   = va   or Enum.VerticalAlignment.Top
	l.SortOrder         = Enum.SortOrder.LayoutOrder
	l.Parent            = parent
	return l
end

function U.label(parent, text, size, color, font, ha)
	local l = Instance.new("TextLabel")
	l.Size            = UDim2.new(1, 0, 0, size or 14)
	l.BackgroundTransparency = 1
	l.Text            = text  or ""
	l.TextSize        = size  or 12
	l.TextColor3      = color or THEME.TEXT2
	l.Font            = font  or THEME.FONT
	l.TextXAlignment  = ha    or Enum.TextXAlignment.Left
	l.Parent          = parent
	return l
end

function U.frame(parent, size, pos, color, trans)
	local f = Instance.new("Frame")
	f.Size                  = size  or UDim2.new(1, 0, 0, 20)
	f.Position              = pos   or UDim2.new(0, 0, 0, 0)
	f.BackgroundColor3      = color or THEME.BG2
	f.BackgroundTransparency = trans or 0
	f.BorderSizePixel       = 0
	f.Parent                = parent
	return f
end

function U.button(parent, text, size, pos)
	local b = Instance.new("TextButton")
	b.Size                  = size or UDim2.new(0, 70, 0, 24)
	b.Position              = pos  or UDim2.new(0, 0, 0, 0)
	b.BackgroundColor3      = THEME.BG3
	b.TextColor3            = THEME.TEXT1
	b.Text                  = text or "Button"
	b.TextSize              = 11
	b.Font                  = THEME.FONT
	b.BorderSizePixel       = 0
	b.AutoButtonColor       = false
	b.Parent                = parent
	U.corner(b, THEME.RAD_ELEM)
	U.stroke(b, THEME.BORDER2)
	-- hover
	b.MouseEnter:Connect(function()
		U.tween(b, {BackgroundColor3 = THEME.BG_HOVER, TextColor3 = THEME.TEXT0})
	end)
	b.MouseLeave:Connect(function()
		U.tween(b, {BackgroundColor3 = THEME.BG3, TextColor3 = THEME.TEXT1})
	end)
	return b
end

-- clamp
function U.clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end

-- hex helpers
function U.toHex(c)
	return string.format("#%02x%02x%02x",
		math.round(c.R * 255),
		math.round(c.G * 255),
		math.round(c.B * 255))
end

function U.fromHex(h)
	h = h:gsub("#","")
	local r = tonumber(h:sub(1,2),16) or 0
	local g = tonumber(h:sub(3,4),16) or 0
	local b = tonumber(h:sub(5,6),16) or 0
	return Color3.fromRGB(r,g,b)
end

-- HSV ↔ RGB (Roblox Color3 already has toHSV / fromHSV)
function U.hsvToColor3(h,s,v)
	return Color3.fromHSV(h/360, s, v)
end

function U.color3ToHSV(c)
	local h,s,v = Color3.toHSV(c)
	return h*360, s, v
end

-- ============================================================
-- SCREEN GUI SETUP
-- ============================================================
function ClientLib.new(title)
	local self = setmetatable({}, ClientLib)

	self.Title   = title or "Client"
	self.Tabs    = {}
	self.ActiveTab = nil
	self.Accent  = THEME.ACCENT
	self.Modules = {} -- flat list for callbacks
	self.KeybindMap = {} -- key -> callback

	-- Root ScreenGui
	local sg = Instance.new("ScreenGui")
	sg.Name             = "ClientLibGUI"
	sg.ResetOnSpawn     = false
	sg.ZIndexBehavior   = Enum.ZIndexBehavior.Sibling
	sg.IgnoreGuiInset   = true
	sg.Parent           = LocalPlayer:WaitForChild("PlayerGui")
	self.ScreenGui      = sg

	-- Main Window Frame
	local win = Instance.new("Frame")
	win.Name                 = "Window"
	win.Size                 = UDim2.new(0, THEME.WIN_W, 0, THEME.WIN_H)
	win.Position             = UDim2.new(0.5, -THEME.WIN_W/2, 0.5, -THEME.WIN_H/2)
	win.BackgroundColor3     = THEME.BG0
	win.BorderSizePixel      = 0
	win.ClipsDescendants     = true
	win.Parent               = sg
	U.corner(win, THEME.RAD_WIN)
	U.stroke(win, THEME.BORDER)
	self.Window = win

	-- Make window draggable
	self:_makeDraggable(win)

	-- Content area (scrolling)
	local scroll = Instance.new("ScrollingFrame")
	scroll.Name                   = "ContentArea"
	scroll.Size                   = UDim2.new(1, 0, 1, -THEME.TAB_H)
	scroll.Position               = UDim2.new(0, 0, 0, 0)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel        = 0
	scroll.ScrollBarThickness     = 4
	scroll.ScrollBarImageColor3   = THEME.BG4
	scroll.CanvasSize             = UDim2.new(0, 0, 0, 0)
	scroll.AutomaticCanvasSize    = Enum.AutomaticSize.Y
	scroll.Parent                 = win
	self.ContentArea = scroll

	-- Tab container (bottom bar)
	local tabBar = U.frame(win,
		UDim2.new(1, 0, 0, THEME.TAB_H),
		UDim2.new(0, 0, 1, -THEME.TAB_H),
		THEME.BG1)
	U.stroke(tabBar, THEME.BORDER)
	-- top border line only via UIStroke won't work perfectly, so add a line frame:
	local topLine = U.frame(tabBar, UDim2.new(1,0,0,1), UDim2.new(0,0,0,0), THEME.BORDER)
	topLine.ZIndex = 2
	self.TabBar = tabBar

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.FillDirection       = Enum.FillDirection.Horizontal
	tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	tabLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
	tabLayout.Padding             = UDim.new(0, 6)
	tabLayout.SortOrder           = Enum.SortOrder.LayoutOrder
	tabLayout.Parent              = tabBar

	self._tabLayout = tabLayout

	-- Color Picker popup (built once, shared)
	self._colorPicker = self:_buildColorPicker()

	-- Key input handler
	UserInputService.InputBegan:Connect(function(inp, gpe)
		if gpe then return end
		if inp.UserInputType == Enum.UserInputType.Keyboard then
			local key = inp.KeyCode
			if self.KeybindMap[key] then
				self.KeybindMap[key]()
			end
		end
	end)

	return self
end

-- ============================================================
-- DRAGGABLE WINDOW
-- ============================================================
function ClientLib:_makeDraggable(frame)
	local dragging, dragStart, startPos
	frame.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			-- only drag if clicking on bg (not a button inside)
			dragging  = true
			dragStart = inp.Position
			startPos  = frame.Position
		end
	end)
	frame.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = inp.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end

-- ============================================================
-- ADD TAB
-- ============================================================
function ClientLib:addTab(name, icon)
	-- icon = Roblox image asset id string or "" 
	local tabData = {
		Name    = name,
		Icon    = icon,
		Modules = {},
		Page    = nil,
		Button  = nil,
	}

	-- Page frame inside ContentArea
	local page = U.frame(self.ContentArea,
		UDim2.new(1, 0, 1, 0),
		UDim2.new(0, 0, 0, 0),
		Color3.fromRGB(0,0,0), 1)
	page.Name    = "Page_" .. name
	page.Visible = false
	page.ClipsDescendants = false

	-- Grid layout using UIGridLayout
	local grid = Instance.new("UIGridLayout")
	grid.CellSize         = UDim2.new(1/THEME.COL_COUNT, -7, 0, 0)
	grid.CellPaddingX	  = UDim2.new(0, THEME.COL_GAP, 0, 0)
	grid.CellPaddingY	  = UDim2.new(0, THEME.COL_GAP, 0, 0)
	-- We'll use manual positioning instead for variable height modules
	-- So remove grid and use UIListLayout in columns:
	grid:Destroy()

	-- Use 3 column frames with list layouts
	local colContainer = U.frame(page,
		UDim2.new(1, -36, 1, 0),
		UDim2.new(0, 18, 0, 18),
		Color3.fromRGB(0,0,0), 1)
	colContainer.Name = "ColContainer"

	local colLayout = Instance.new("UIListLayout")
	colLayout.FillDirection = Enum.FillDirection.Horizontal
	colLayout.Padding       = UDim.new(0, THEME.COL_GAP)
	colLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	colLayout.VerticalAlignment   = Enum.VerticalAlignment.Top
	colLayout.SortOrder   = Enum.SortOrder.LayoutOrder
	colLayout.Parent      = colContainer

	local cols = {}
	for i = 1, THEME.COL_COUNT do
		local col = U.frame(colContainer,
			UDim2.new(1/THEME.COL_COUNT, -(THEME.COL_GAP*(THEME.COL_COUNT-1)/THEME.COL_COUNT), 0, 2000),
			UDim2.new(0,0,0,0),
			Color3.fromRGB(0,0,0), 1)
		col.Name         = "Col" .. i
		col.LayoutOrder  = i
		col.AutomaticSize = Enum.AutomaticSize.Y
		U.listLayout(col, Enum.FillDirection.Vertical, THEME.COL_GAP)
		cols[i] = col
	end

	tabData.Page    = page
	tabData.Cols    = cols
	tabData.ColIdx  = 1  -- current column to add to (round-robin)

	-- Tab Button
	local btn = Instance.new("TextButton")
	btn.Name             = "TabBtn_" .. name
	btn.Size             = UDim2.new(0, 44, 0, 40)
	btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
	btn.BackgroundTransparency = 1
	btn.BorderSizePixel  = 0
	btn.AutoButtonColor  = false
	btn.Text             = ""
	btn.Font             = THEME.FONT
	btn.TextSize         = 13
	btn.LayoutOrder      = #self.Tabs + 1
	btn.Parent           = self.TabBar
	U.corner(btn, 12)

	-- Icon label
	local iconLbl = Instance.new("TextLabel")
	iconLbl.Name                 = "Icon"
	iconLbl.Size                 = UDim2.new(0, 20, 1, 0)
	iconLbl.Position             = UDim2.new(0, 12, 0, 0)
	iconLbl.BackgroundTransparency = 1
	iconLbl.Text                 = icon or name:sub(1,1)
	iconLbl.TextSize             = 14
	iconLbl.Font                 = THEME.FONT_BOLD
	iconLbl.TextColor3           = THEME.TEXT3
	iconLbl.TextXAlignment       = Enum.TextXAlignment.Center
	iconLbl.Parent               = btn

	-- Name label (hidden, expands on active)
	local nameLbl = Instance.new("TextLabel")
	nameLbl.Name                 = "Label"
	nameLbl.Size                 = UDim2.new(0, 0, 1, 0)
	nameLbl.Position             = UDim2.new(0, 38, 0, 0)
	nameLbl.BackgroundTransparency = 1
	nameLbl.Text                 = name
	nameLbl.TextSize             = 13
	nameLbl.Font                 = THEME.FONT
	nameLbl.TextColor3           = THEME.ACCENT
	nameLbl.TextXAlignment       = Enum.TextXAlignment.Left
	nameLbl.ClipsDescendants     = true
	nameLbl.Visible              = false
	nameLbl.Parent               = btn

	tabData.Button   = btn
	tabData.IconLbl  = iconLbl
	tabData.NameLbl  = nameLbl

	-- Click handler
	btn.MouseButton1Click:Connect(function()
		self:_selectTab(tabData)
	end)
	btn.MouseEnter:Connect(function()
		if self.ActiveTab ~= tabData then
			U.tween(iconLbl, {TextColor3 = THEME.TEXT2}, 0.15)
			U.tween(btn, {BackgroundTransparency = 0.85}, 0.15)
			btn.BackgroundColor3 = THEME.BG0
		end
	end)
	btn.MouseLeave:Connect(function()
		if self.ActiveTab ~= tabData then
			U.tween(iconLbl, {TextColor3 = THEME.TEXT3}, 0.15)
			U.tween(btn, {BackgroundTransparency = 1}, 0.15)
		end
	end)

	table.insert(self.Tabs, tabData)

	-- Select first tab automatically
	if #self.Tabs == 1 then
		self:_selectTab(tabData)
	end

	return tabData
end

function ClientLib:_selectTab(tabData)
	-- Hide all pages, deactivate all buttons
	for _, td in ipairs(self.Tabs) do
		td.Page.Visible = false
		td.NameLbl.Visible = false
		U.tween(td.Button, {BackgroundTransparency = 1, BackgroundColor3 = THEME.BG0}, 0.2)
		U.tween(td.IconLbl, {TextColor3 = THEME.TEXT3}, 0.2)
		td.Button.Size = UDim2.new(0, 44, 0, 40)
	end
	-- Show selected
	tabData.Page.Visible = true
	tabData.NameLbl.Visible = true
	tabData.Button.BackgroundTransparency = 0
	tabData.Button.BackgroundColor3 = THEME.BG2
	tabData.NameLbl.TextColor3 = self.Accent
	U.tween(tabData.IconLbl, {TextColor3 = self.Accent}, 0.2)

	-- Expand button size
	local textW = tabData.Button:FindFirstChild("Label")
	-- Animate width
	local targetW = 44 + 10 + string.len(tabData.Name) * 8
	U.tween(tabData.Button, {Size = UDim2.new(0, targetW, 0, 40)}, 0.3)

	self.ActiveTab = tabData
	self._colorPicker.Frame.Visible = false
end

-- ============================================================
-- ADD MODULE  (returns module handle for adding elements)
-- ============================================================
function ClientLib:addModule(tabData, moduleName, defaultEnabled)
	local col = tabData.Cols[tabData.ColIdx]
	tabData.ColIdx = (tabData.ColIdx % THEME.COL_COUNT) + 1

	-- Module frame
	local modFrame = U.frame(col,
		UDim2.new(1, 0, 0, 0),
		UDim2.new(0,0,0,0),
		THEME.BG2)
	modFrame.Name         = "Module_" .. moduleName
	modFrame.AutomaticSize = Enum.AutomaticSize.Y
	modFrame.LayoutOrder  = #tabData.Modules + 1
	U.corner(modFrame, THEME.RAD_MOD)
	U.stroke(modFrame, THEME.BORDER)
	U.padding(modFrame, THEME.MOD_PAD, THEME.MOD_PAD, THEME.MOD_PAD, THEME.MOD_PAD)

	local modLayout = U.listLayout(modFrame, Enum.FillDirection.Vertical, 10)

	-- Header row
	local header = U.frame(modFrame, UDim2.new(1,0,0,20), UDim2.new(0,0,0,0), Color3.fromRGB(0,0,0), 1)
	header.Name = "Header"
	header.LayoutOrder = 0

	local headerLayout = Instance.new("UIListLayout")
	headerLayout.FillDirection       = Enum.FillDirection.Horizontal
	headerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	headerLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
	headerLayout.SortOrder           = Enum.SortOrder.LayoutOrder
	headerLayout.Parent              = header

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size                  = UDim2.new(1, -46, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text                  = moduleName
	nameLabel.TextSize              = 13
	nameLabel.Font                  = THEME.FONT_BOLD
	nameLabel.TextColor3            = THEME.TEXT0
	nameLabel.TextXAlignment        = Enum.TextXAlignment.Left
	nameLabel.LayoutOrder           = 1
	nameLabel.Parent                = header

	-- Toggle
	local enabled = defaultEnabled or false
	local toggleBtn, toggleDot = self:_buildToggle(header, enabled)
	toggleBtn.LayoutOrder = 2

	local moduleData = {
		Name      = moduleName,
		Frame     = modFrame,
		Enabled   = enabled,
		OnToggle  = nil,
		ElemCount = 1,
	}

	-- Toggle logic
	toggleBtn.MouseButton1Click:Connect(function()
		moduleData.Enabled = not moduleData.Enabled
		self:_animateToggle(toggleDot, moduleData.Enabled)
		if moduleData.OnToggle then
			moduleData.OnToggle(moduleData.Enabled)
		end
	end)

	-- If defaultEnabled draw correct state
	if enabled then
		toggleDot.Position = UDim2.new(0, 19, 0.5, -7)
		toggleDot.BackgroundColor3 = self.Accent
	end

	table.insert(tabData.Modules, moduleData)
	return moduleData
end

-- ============================================================
-- TOGGLE BUILDER
-- ============================================================
function ClientLib:_buildToggle(parent, enabled)
	local track = Instance.new("TextButton")
	track.Name               = "Toggle"
	track.Size               = UDim2.new(0, 36, 0, 20)
	track.BackgroundColor3   = THEME.BG4
	track.BorderSizePixel    = 0
	track.Text               = ""
	track.AutoButtonColor    = false
	track.Parent             = parent
	U.corner(track, 10)

	local dot = Instance.new("Frame")
	dot.Name               = "Dot"
	dot.Size               = UDim2.new(0, 14, 0, 14)
	dot.Position           = UDim2.new(0, 3, 0.5, -7)
	dot.BackgroundColor3   = enabled and THEME.ACCENT or THEME.TEXT3
	dot.BorderSizePixel    = 0
	dot.ZIndex             = 3
	dot.Parent             = track
	U.corner(dot, 7)

	return track, dot
end

function ClientLib:_buildMiniToggle(parent, enabled)
	local track = Instance.new("TextButton")
	track.Name             = "MiniToggle"
	track.Size             = UDim2.new(0, 28, 0, 16)
	track.BackgroundColor3 = THEME.BG4
	track.BorderSizePixel  = 0
	track.Text             = ""
	track.AutoButtonColor  = false
	track.Parent           = parent
	U.corner(track, 8)

	local dot = Instance.new("Frame")
	dot.Name               = "Dot"
	dot.Size               = UDim2.new(0, 10, 0, 10)
	dot.Position           = UDim2.new(0, 3, 0.5, -5)
	dot.BackgroundColor3   = enabled and THEME.ACCENT or THEME.TEXT3
	dot.BorderSizePixel    = 0
	dot.ZIndex             = 3
	dot.Parent             = track
	U.corner(dot, 5)

	if enabled then
		dot.Position = UDim2.new(0, 15, 0.5, -5)
		dot.BackgroundColor3 = self.Accent
	end

	return track, dot
end

function ClientLib:_animateToggle(dot, enabled, mini)
	local onPos  = mini and UDim2.new(0, 15, 0.5, -5) or UDim2.new(0, 19, 0.5, -7)
	local offPos = mini and UDim2.new(0, 3, 0.5, -5)  or UDim2.new(0, 3, 0.5, -7)
	U.tween(dot, {
		Position         = enabled and onPos or offPos,
		BackgroundColor3 = enabled and self.Accent or THEME.TEXT3,
	}, 0.25, Enum.EasingStyle.Quad)
end

-- ============================================================
-- MODULE ELEMENT: TOGGLE (on:change callback)
-- ============================================================
function ClientLib:addToggle(moduleData, labelText, default, onChange)
	local enabled = default or false

	local row = U.frame(moduleData.Frame,
		UDim2.new(1, 0, 0, 20),
		UDim2.new(0,0,0,0),
		Color3.fromRGB(0,0,0), 1)
	row.Name         = "ToggleRow_" .. labelText
	row.LayoutOrder  = moduleData.ElemCount
	moduleData.ElemCount += 1

	local lbl = U.label(row, labelText, 11, THEME.TEXT2, THEME.FONT)
	lbl.Size = UDim2.new(1, -38, 1, 0)
	lbl.TextYAlignment = Enum.TextYAlignment.Center

	local track, dot = self:_buildMiniToggle(row, enabled)
	track.Position  = UDim2.new(1, -28, 0.5, -8)
	track.AnchorPoint = Vector2.new(0, 0)

	local state = {Value = enabled}
	track.MouseButton1Click:Connect(function()
		state.Value = not state.Value
		self:_animateToggle(dot, state.Value, true)
		if onChange then onChange(state.Value) end
	end)

	return state
end

-- ============================================================
-- MODULE ELEMENT: SLIDER
-- ============================================================
function ClientLib:addSlider(moduleData, labelText, min, max, default, step, suffix, onChange)
	min    = min    or 0
	max    = max    or 100
	default = default or min
	step   = step   or 1
	suffix = suffix or ""

	local container = U.frame(moduleData.Frame,
		UDim2.new(1,0,0,36),
		UDim2.new(0,0,0,0),
		Color3.fromRGB(0,0,0), 1)
	container.Name        = "Slider_" .. labelText
	container.LayoutOrder = moduleData.ElemCount
	moduleData.ElemCount  += 1
	U.listLayout(container, Enum.FillDirection.Vertical, 4)

	-- Row: label + value
	local labelRow = U.frame(container, UDim2.new(1,0,0,14), nil, Color3.fromRGB(0,0,0), 1)
	labelRow.Name = "LabelRow"

	local lbl = U.label(labelRow, labelText, 11, THEME.TEXT2, THEME.FONT)
	lbl.Size = UDim2.new(0.5,0,1,0)

	local function fmt(v)
		if step >= 1 then return tostring(v) .. suffix
		else return string.format("%.1f", v) .. suffix end
	end

	local valLbl = Instance.new("TextLabel")
	valLbl.Size              = UDim2.new(0.5,0,1,0)
	valLbl.Position          = UDim2.new(0.5,0,0,0)
	valLbl.BackgroundTransparency = 1
	valLbl.Text              = fmt(default)
	valLbl.TextSize          = 11
	valLbl.Font              = THEME.FONT
	valLbl.TextColor3        = THEME.TEXT1
	valLbl.TextXAlignment    = Enum.TextXAlignment.Right
	valLbl.Parent            = labelRow

	-- Track
	local trackWrap = U.frame(container, UDim2.new(1,0,0,16), nil, Color3.fromRGB(0,0,0), 1)
	trackWrap.Name = "TrackWrap"

	local track = U.frame(trackWrap, UDim2.new(1,0,0,4), UDim2.new(0,0,0.5,-2), THEME.BG4)
	track.Name = "Track"
	U.corner(track, 2)

	local fill = U.frame(track, UDim2.new(0,0,1,0), nil, self.Accent)
	fill.Name = "Fill"
	U.corner(fill, 2)

	local thumb = Instance.new("TextButton")
	thumb.Name             = "Thumb"
	thumb.Size             = UDim2.new(0, 12, 0, 12)
	thumb.Position         = UDim2.new(0, 0, 0.5, -6)
	thumb.BackgroundColor3 = THEME.TEXT0
	thumb.BorderSizePixel  = 0
	thumb.Text             = ""
	thumb.AutoButtonColor  = false
	thumb.ZIndex           = 5
	thumb.Parent           = track
	U.corner(thumb, 6)

	-- State
	local state = {Value = default}
	local function ratio() return (state.Value - min) / (max - min) end
	local function setVal(v)
		v = U.clamp(v, min, max)
		v = math.round(v / step) * step
		state.Value = v
		local r = ratio()
		fill.Size    = UDim2.new(r, 0, 1, 0)
		thumb.Position = UDim2.new(r, -6, 0.5, -6)
		valLbl.Text  = fmt(v)
		if onChange then onChange(v) end
	end
	setVal(default)

	-- Drag logic
	local dragging = false
	local function applyMouse(x)
		local abs = track.AbsolutePosition
		local w   = track.AbsoluteSize.X
		local r   = U.clamp((x - abs.X) / w, 0, 1)
		local raw = min + r * (max - min)
		setVal(raw)
	end

	thumb.MouseButton1Down:Connect(function() dragging = true end)
	track.MouseButton1Down:Connect(function(x,_) dragging = true; applyMouse(x + track.AbsolutePosition.X) end)

	-- Use InputChanged for smooth dragging
	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			applyMouse(inp.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	return state
end

