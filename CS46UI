function ClientLib:addKeybind(moduleData, labelText, default, onBind)
	local currentKey = default or Enum.KeyCode.Unknown

	local row = U.frame(moduleData.Frame, UDim2.new(1,0,0,20), nil, Color3.fromRGB(0,0,0), 1)
	row.Name        = "Keybind_" .. labelText
	row.LayoutOrder = moduleData.ElemCount
	moduleData.ElemCount += 1

	local lbl = U.label(row, labelText, 11, THEME.TEXT2, THEME.FONT)
	lbl.Size = UDim2.new(0.6,0,1,0)

	local function keyName(k)
		if k == Enum.KeyCode.Unknown then return "—" end
		return k.Name:upper()
	end

	local bindBtn = Instance.new("TextButton")
	bindBtn.Name             = "BindBtn"
	bindBtn.Size             = UDim2.new(0, 64, 0, 18)
	bindBtn.Position         = UDim2.new(1,-64,0.5,-9)
	bindBtn.BackgroundColor3 = THEME.BG3
	bindBtn.BorderSizePixel  = 0
	bindBtn.Text             = keyName(currentKey)
	bindBtn.TextSize         = 10
	bindBtn.Font             = THEME.FONT
	bindBtn.TextColor3       = THEME.TEXT2
	bindBtn.AutoButtonColor  = false
	bindBtn.Parent           = row
	U.corner(bindBtn, THEME.RAD_SMALL)
	U.stroke(bindBtn, THEME.BORDER2)

	local listening = false
	local conn

	bindBtn.MouseButton1Click:Connect(function()
		if listening then return end
		listening = true
		bindBtn.Text       = "..."
		bindBtn.TextColor3 = THEME.TEXT1
		if conn then conn:Disconnect() end
		conn = UserInputService.InputBegan:Connect(function(inp, gpe)
			if gpe then return end
			if inp.UserInputType == Enum.UserInputType.Keyboard then
				listening = false
				conn:Disconnect()
				if inp.KeyCode == Enum.KeyCode.Escape then
					currentKey         = Enum.KeyCode.Unknown
					bindBtn.Text       = "—"
					bindBtn.TextColor3 = THEME.TEXT2
				else
					currentKey         = inp.KeyCode
					bindBtn.Text       = keyName(currentKey)
					bindBtn.TextColor3 = THEME.TEXT2
					-- Register keybind
					self.KeybindMap[currentKey] = function()
						if onBind then onBind(currentKey) end
					end
				end
			end
		end)
	end)

	return {getKey = function() return currentKey end}
end

