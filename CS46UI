function ClientUI.new(config)
    config = config or {}
    local self = setmetatable({}, ClientUI)
    
    self.Title = config.Title or "Client"
    self.Size = config.Size or UDim2.new(0, 820, 0, 560)
    self.Theme = Theme.new()
    self.Tabs = {}
    self.ActiveTab = nil
    self.OpenDropdown = nil
    self.ColorPickerOpen = nil
    self.Flags = {}
    self.ToggleKey = config.ToggleKey or Enum.KeyCode.RightShift
    self.Visible = true
    
    self:Build()
    
    -- Toggle visibility
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == self.ToggleKey then
            self:SetVisible(not self.Visible)
        end
    end)
    
    return self
end

function ClientUI:Build()
    local theme = self.Theme
    
    -- ScreenGui
    self.ScreenGui = Util.Create("ScreenGui", {
        Name = "ClientUI",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
