function ClientLib:addMultiDropdown(moduleData, labelText, options, defaults, onChange)
	defaults = defaults or {}
	local selected = {}
	for _, d in ipairs(defaults) do selected[d] = true end

	local function getSelected()
		local out = {}
		for _, o in ipairs(options) do
			if selected[o] then table.insert(out, o) end
		end
		return out
	end

	local function summaryText()
		local s = getSelected()
		return #s > 0 and table.concat(s, ", ") or "None"
	end

	local container = U.frame(moduleData.Frame,
		UDim2.new(1,0,0,0), nil, Color3.fromRGB(0,0,0), 1)
	container.Name        = "MultiDD_" .. labelText
	container.LayoutOrder = moduleData.ElemCount
	container.AutomaticSize = Enum.AutomaticSize.Y
	moduleData.ElemCount  += 1
	U.listLayout(container, Enum.FillDirection.Vertical, 4)

	local lbl = U.label(container, labelText, 11, THEME.TEXT2, THEME.FONT)
	lbl.LayoutOrder = 0

	local selBtn = Instance.new("TextButton")
	selBtn.Size             = UDim2.new(1,0,0,24)
	selBtn.BackgroundColor3 = THEME.BG3
	selBtn.BorderSizePixel  = 0
	selBtn.Text             = ""
	selBtn.AutoButtonColor  = false
	selBtn.LayoutOrder      = 1
	selBtn.Parent           = container
	U.corner(selBtn, THEME.RAD_ELEM)
	U.stroke(selBtn, THEME.BORDER2)

	local selText = Instance.new("TextLabel")
	selText.Size           = UDim2.new(1,-24,1,0)
	selText.Position       = UDim2.new(0,10,0,0)
	selText.BackgroundTransparency = 1
	selText.Text           = summaryText()
	selText.TextSize       = 11
	selText.Font           = THEME.FONT
	selText.TextColor3     = THEME.TEXT1
	selText.TextXAlignment = Enum.TextXAlignment.Left
	selText.Parent         = selBtn

	local chevron = Instance.new("TextLabel")
	chevron.Size           = UDim2.new(0,16,1,0)
	chevron.Position       = UDim2.new(1,-20,0,0)
	chevron.BackgroundTransparency = 1
	chevron.Text           = "▾"
	chevron.TextSize       = 11
	chevron.Font           = THEME.FONT
	chevron.TextColor3     = THEME.TEXT3
	chevron.TextXAlignment = Enum.TextXAlignment.Center
	chevron.Parent         = selBtn

	local listHolder = U.frame(container,
		UDim2.new(1,0,0,0), nil, THEME.BG3)
	listHolder.AutomaticSize = Enum.AutomaticSize.Y
	listHolder.LayoutOrder  = 2
	listHolder.Visible      = false
	U.corner(listHolder, THEME.RAD_ELEM)
	U.stroke(listHolder, THEME.BORDER2)
	U.listLayout(listHolder, Enum.FillDirection.Vertical, 0)

	local checkboxes = {}

	for i, opt in ipairs(options) do
		local item = Instance.new("TextButton")
		item.Size             = UDim2.new(1,0,0,24)
		item.BackgroundColor3 = THEME.BG3
		item.BorderSizePixel  = 0
		item.Text             = ""
		item.AutoButtonColor  = false
		item.LayoutOrder      = i
		item.Parent           = listHolder

		-- Checkbox box
		local box = U.frame(item, UDim2.new(0,12,0,12), UDim2.new(0,8,0.5,-6), THEME.BG4)
		U.corner(box, 3)
		U.stroke(box, THEME.BORDER2)

		-- Inner fill
		local boxFill = U.frame(box, UDim2.new(0,6,0,6), UDim2.new(0.5,-3,0.5,-3), self.Accent)
		boxFill.Name    = "Fill"
		boxFill.Visible = selected[opt] or false
		U.corner(boxFill, 2)

		local itemTxt = Instance.new("TextLabel")
		itemTxt.Size           = UDim2.new(1,-28,1,0)
		itemTxt.Position       = UDim2.new(0,28,0,0)
		itemTxt.BackgroundTransparency = 1
		itemTxt.Text           = opt
		itemTxt.TextSize       = 11
		itemTxt.Font           = THEME.FONT
		itemTxt.TextColor3     = THEME.TEXT1
		itemTxt.TextXAlignment = Enum.TextXAlignment.Left
		itemTxt.Parent         = item

		checkboxes[opt] = boxFill

		item.MouseEnter:Connect(function()
			U.tween(item, {BackgroundColor3 = THEME.BG_HOVER}, 0.1)
		end)
		item.MouseLeave:Connect(function()
			U.tween(item, {BackgroundColor3 = THEME.BG3}, 0.1)
		end)
		item.MouseButton1Click:Connect(function()
			selected[opt]        = not selected[opt]
			boxFill.Visible      = selected[opt]
			selText.Text         = summaryText()
			if onChange then onChange(getSelected()) end
		end)
	end

	selBtn.MouseButton1Click:Connect(function()
		if listHolder.Visible then
			listHolder.Visible = false; chevron.Text = "▾"
		else
			listHolder.Visible = true;  chevron.Text = "▴"
		end
	end)

	local state = {getSelected = getSelected}
	return state
end

