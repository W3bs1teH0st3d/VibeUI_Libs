function ClientUI:SetBackground(imageId, opacity)
    if imageId and imageId ~= "" then
        self.BGOverlay.Image = imageId
        self.BGOverlay.ImageTransparency = 1 - (opacity or 0.06)
        self.BGOverlay.Visible = true
    else
        self.BGOverlay.Visible = false
        self.BGOverlay.Image = ""
    end
end

function ClientUI:SetBackgroundOpacity(opacity)
    self.BGOverlay.ImageTransparency = 1 - opacity
end

