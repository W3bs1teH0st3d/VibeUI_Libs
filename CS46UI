        callback = nil,
        dragging = nil,
    }
    
    -- SV dragging
    local function updateSV(input)
        local absPos = svFrame.AbsolutePosition
        local absSize = svFrame.AbsoluteSize
        local relX = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
        local relY = math.clamp((input.Position.Y - absPos.Y) / absSize.Y, 0, 1)
        self.CP.s = relX
        self.CP.v = 1 - relY
        self:UpdateColorPicker()
    end
    
    local function updateHue(input)
        local absPos = hueFrame.AbsolutePosition
        local absSize = hueFrame.AbsoluteSize
        local relX = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
        self.CP.h = relX
        self:UpdateColorPicker()
    end
    
    svBtn.MouseButton1Down:Connect(function()
        self.CP.dragging = "sv"
        local input = {Position = Vector3.new(Mouse.X, Mouse.Y, 0)}
        updateSV(input)
    end)
    
    hueBtn.MouseButton1Down:Connect(function()
        self.CP.dragging = "hue"
        local input = {Position = Vector3.new(Mouse.X, Mouse.Y, 0)}
        updateHue(input)
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if not self.CP.dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        
        if self.CP.dragging == "sv" then
            updateSV(input)
        elseif self.CP.dragging == "hue" then
            updateHue(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.CP.dragging = nil
        end
    end)
    
    hexInput.FocusLost:Connect(function()
        local hex = hexInput.Text:gsub("#", "")
        if #hex >= 6 then
            local color = Util.HexToColor3("#" .. hex)
            local h, s, v = Util.RGBtoHSV(color)
            self.CP.h = h
            self.CP.s = s
            self.CP.v = v
            self:UpdateColorPicker()
        end
    end)
end

function ClientUI:UpdateColorPicker()
    local cp = self.CP
    local color = Color3.fromHSV(cp.h, cp.s, cp.v)
    local hueColor = Color3.fromHSV(cp.h, 1, 1)
    
    -- Update SV background
    cp.svFrame.BackgroundColor3 = hueColor
    
    -- Update cursors
    cp.svCursor.Position = UDim2.new(cp.s, -7, 1 - cp.v, -7)
    cp.hueCursor.Position = UDim2.new(cp.h, -3, 0.5, -9)
    
    -- Update preview
    cp.preview.BackgroundColor3 = color
    
    -- Update hex
    cp.hexInput.Text = Util.Hex(color)
    
    -- Fire callback
    if cp.callback then
        cp.callback(color)
    end
end

function ClientUI:OpenColorPicker(currentColor, callback)
    local h, s, v = Util.RGBtoHSV(currentColor)
    self.CP.h = h
    self.CP.s = s
    self.CP.v = v
    self.CP.callback = callback
    
    -- Position near mouse
    local mx, my = Mouse.X, Mouse.Y
    local vpSize = workspace.CurrentCamera.ViewportSize
    local px = math.clamp(mx, 10, vpSize.X - 250)
    local py = math.clamp(my, 10, vpSize.Y - 260)
    
    self.CPPopup.Position = UDim2.new(0, px, 0, py)
    self.CPPopup.Visible = true
    
    self:UpdateColorPicker()
    
    -- Close on outside click (next frame)
    if self._cpCloseConn then self._cpCloseConn:Disconnect() end
    self._cpCloseConn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Check if click is outside popup
            task.defer(function()
                local pos = self.CPPopup.AbsolutePosition
                local size = self.CPPopup.AbsoluteSize
                local mx, my = Mouse.X, Mouse.Y
                if mx < pos.X or mx > pos.X + size.X or my < pos.Y or my > pos.Y + size.Y then
                    -- Don't close if clicking on swatch
                    -- Simple delay approach
                    task.delay(0.05, function()
                        if self.CP.dragging then return end
                        -- self:CloseColorPicker()
                    end)
                end
            end)
        end
    end)
end

function ClientUI:CloseColorPicker()
    self.CPPopup.Visible = false
    self.CP.callback = nil
    self.CP.dragging = nil
    if self._cpCloseConn then
        self._cpCloseConn:Disconnect()
        self._cpCloseConn = nil
    end
end

function ClientUI:CloseAllDropdowns()
    if self.OpenDropdown then
        self.OpenDropdown.close()
        self.OpenDropdown = nil
    end
end

-- ============================================================
-- APPLY THEME
-- ============================================================
function ClientUI:ApplyTheme()
    local t = self.Theme
    
    self.MainFrame.BackgroundColor3 = t.BG0
    local stroke = self.MainFrame:FindFirstChild("MainStroke")
    if stroke then stroke.Color = t.Border end
    
    self.TabBar.BackgroundColor3 = t.BG1
    local topCover = self.TabBar:FindFirstChild("TopCover")
    if topCover then topCover.BackgroundColor3 = t.BG1 end
    local topBorder = self.TabBar:FindFirstChild("TopBorder")
    if topBorder then topBorder.BackgroundColor3 = t.Border end
    
    self.ContentFrame.ScrollBarImageColor3 = t.BG4
    
    -- Update active tab visuals
    for _, tab in ipairs(self.Tabs) do
        if tab == self.ActiveTab then
            tab.IconLabel.TextColor3 = t.Accent
            tab.TextLabel.TextColor3 = t.Accent
            tab.Button.BackgroundColor3 = t.BG2
        else
            tab.IconLabel.TextColor3 = t.Text3
            tab.Button.BackgroundTransparency = 1
        end
    end
    
    -- Color picker popup
    if self.CPPopup then
        self.CPPopup.BackgroundColor3 = t.BG2
    end
end

